# Backend
APP_ENV=local
DATABASE_URL=sqlite:///./app.db
FRONTEND_ORIGIN=http://localhost:5173

# OpenAI receipt extraction. Leave blank for fixture fallback mode.
OPENAI_API_KEY=
OPENAI_MODEL_RECEIPT=
OPENAI_REQUEST_TIMEOUT_SECONDS=45

# Open Food Facts. Live lookup is opt-in so the demo stays reliable offline.
OPEN_FOOD_FACTS_LIVE=false
OPEN_FOOD_FACTS_USER_AGENT=BunqBiteBalance/0.1 hackathon-demo contact:local@example.invalid

# bunq sandbox. Leave blank for seeded transaction fallback mode.
BUNQ_API_KEY=
BUNQ_CALLBACK_URL=

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api

